# ── MERVEKS SAP backend configuration ───────────────────────────────
# Copy this file to ".env" and fill in your values.

# MongoDB connection string.
#   • Local Mongo:  mongodb://127.0.0.1:27017
#   • MongoDB Atlas (free M0):
#     mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017

# Database name (created automatically on first write).
DB_NAME=merveks_sap

# Port the API listens on.
PORT=4000

# Allowed browser origin(s) for CORS. Use "*" in dev, your site in prod
# (e.g. https://sap.merveks.com). Comma-separate multiple origins.
CORS_ORIGIN=*

# Secret used to sign login tokens. MUST be a long random string in prod.
JWT_SECRET=change-this-to-a-long-random-secret-string

# Google Gemini API key — kept server-side so it never ships to the browser.
# Leave blank to disable the live AI proxy (offline engine still works).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
